---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import PostCard from "../components/PostCard.astro";
import { collectCategories, collectTags, getAllPosts, getCategoryUrl, getPinnedPosts, getRegularPosts, getTagUrl, withBase } from "../lib/posts";
import { site } from "../lib/site";

const posts = await getAllPosts();
const pinnedPosts = getPinnedPosts(posts);
const latest = getRegularPosts(posts).slice(0, 6);
const categories = collectCategories(posts).slice(0, 6);
const tags = collectTags(posts).slice(0, 12);
const categoryDotColors: Record<string, string> = {
  "大模型": "bg-bark-700",
  "知识管理": "bg-leaf-400",
  "前端": "bg-bark-500",
  "编程": "bg-leaf-500",
  "学习方法": "bg-bark-300",
  "生活系统": "bg-leaf-300",
};
---

<BaseLayout>
  <!-- HERO：纯文字叙事 -->
  <section class="relative mx-auto max-w-4xl pb-4 pt-6 text-center md:pt-10">
    <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-leaf-200 bg-white/70 px-3 py-1.5 text-xs font-semibold text-leaf-700 shadow-soft dark:border-leaf-300/20 dark:bg-white/5 dark:text-leaf-200">
      <span class="grid h-5 w-5 place-items-center rounded-full bg-leaf-500/10 text-leaf-700 dark:text-leaf-200">
        <Icon name="pulse" class="h-3.5 w-3.5" />
      </span>
      daliyMove Tech Notes
    </div>
    <h1 class="font-display text-4xl font-semibold leading-[1.12] tracking-tight text-ink-900 dark:text-ink-50 md:text-5xl lg:text-6xl">
      把每天的技术推进，<br />沉淀成<span class="kw">可复用的分享</span>。
    </h1>
    <p class="mx-auto mt-7 max-w-2xl text-lg leading-8 text-ink-600 dark:text-ink-400">{site.description}</p>
    <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
      <a class="inline-flex items-center gap-2 rounded-xl bg-leaf-600 px-5 py-3 text-sm font-semibold text-white shadow-lift transition hover:-translate-y-0.5 hover:bg-leaf-700 dark:bg-leaf-500 dark:text-ink-950 dark:hover:bg-leaf-400" href={withBase("/blog/")}>
        开始阅读
        <Icon name="arrow" class="h-4 w-4" />
      </a>
      <a class="inline-flex items-center gap-2 rounded-xl border border-ink-200 bg-white/65 px-5 py-3 text-sm font-semibold text-ink-700 transition hover:border-leaf-300 hover:text-leaf-700 dark:border-white/10 dark:bg-white/5 dark:text-ink-100" href={withBase("/about/")}>
        <Icon name="user" class="h-4 w-4" />
        关于 daliyMove
      </a>
    </div>
    <div class="mt-9 flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm text-ink-500 dark:text-ink-400">
      <span class="inline-flex items-center gap-2"><strong class="text-lg text-ink-900 dark:text-ink-50">{posts.length}</strong>篇文章</span>
      <span class="inline-flex items-center gap-2"><strong class="text-lg text-ink-900 dark:text-ink-50">{categories.length}</strong>个分类</span>
      <span class="inline-flex items-center gap-2"><strong class="text-lg text-ink-900 dark:text-ink-50">{tags.length}</strong>个标签</span>
    </div>
  </section>

  <!-- 主编领读 / 置顶 -->
  {pinnedPosts.length > 0 && (
    <section class="border-b border-ink-200/70 py-12 dark:border-white/10">
      <div class="mb-6 flex items-end justify-between gap-4">
        <div>
          <p class="inline-flex items-center gap-2 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-bark-500 dark:text-bark-300">
            <Icon name="pin" class="h-3.5 w-3.5" />
            Editor's Pick
          </p>
          <h2 class="mt-2 font-display text-3xl font-semibold text-ink-900 dark:text-ink-50">主编领读</h2>
        </div>
        <span class="text-sm text-ink-500 dark:text-ink-400">优先阅读与长期维护</span>
      </div>
      <div class="space-y-4">{pinnedPosts.map((post) => <PostCard post={post} featured />)}</div>
    </section>
  )}

  <!-- 最近更新 + 侧栏 -->
  <section class="grid gap-10 pt-12 lg:grid-cols-[minmax(0,1fr)_20rem]">
    <div>
      <div class="mb-6 flex items-center justify-between gap-4">
        <h2 class="font-display text-2xl font-semibold text-ink-900 dark:text-ink-50">最近更新</h2>
        <span class="font-mono text-xs text-ink-400">按发布时间排序</span>
      </div>
      <ol class="trail space-y-4">
        {latest.map((post) => (
          <li class="trail-item"><PostCard post={post} compact /></li>
        ))}
      </ol>
    </div>
    <aside class="space-y-8">
      <section>
        <div class="mb-4 flex items-center justify-between">
          <h2 class="inline-flex items-center gap-2 text-base font-semibold text-ink-900 dark:text-ink-50">
            <Icon name="grid" class="h-4 w-4 text-leaf-600 dark:text-leaf-300" />
            知识分类
          </h2>
          <a class="text-xs text-leaf-700 hover:underline dark:text-leaf-300" href={withBase("/categories/")}>全部</a>
        </div>
        <div class="grid gap-1.5">
          {categories.map(([category, count], index) => (
            <a class="group flex items-center justify-between rounded-xl border border-transparent px-3 py-2 text-sm transition hover:border-leaf-200 hover:bg-leaf-50 dark:hover:border-leaf-300/30 dark:hover:bg-leaf-300/10" href={getCategoryUrl(category)}>
              <span class="flex items-center gap-3">
                <span class:list={["h-2.5 w-2.5 rounded-full", categoryDotColors[category] ?? (index % 2 === 0 ? "bg-leaf-400" : "bg-bark-400")]}></span>
                {category}
              </span>
              <span class="font-mono text-xs text-ink-400 transition group-hover:text-leaf-700 dark:group-hover:text-leaf-300">{count}</span>
            </a>
          ))}
        </div>
      </section>
      <section>
        <h2 class="mb-4 inline-flex items-center gap-2 text-base font-semibold text-ink-900 dark:text-ink-50">
          <Icon name="tag" class="h-4 w-4 text-leaf-600 dark:text-leaf-300" />
          常用标签
        </h2>
        <div class="flex flex-wrap gap-2">
          {tags.map(([tag, count]) => (
            <a class="rounded-full border border-ink-200/80 bg-white/55 px-3 py-1.5 text-xs text-ink-600 transition hover:border-leaf-300 hover:bg-leaf-50 hover:text-leaf-700 dark:border-white/10 dark:bg-white/5 dark:text-ink-200 dark:hover:bg-leaf-300/10 dark:hover:text-leaf-200" href={getTagUrl(tag)}>
              #{tag} <span class="font-mono text-ink-400">{count}</span>
            </a>
          ))}
        </div>
      </section>
    </aside>
  </section>
</BaseLayout>
