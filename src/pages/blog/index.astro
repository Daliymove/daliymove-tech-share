---
import PageHeader from "../../components/PageHeader.astro";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectCategories, getAllPosts, getPinnedPosts, getRegularPosts } from "../../lib/posts";

const posts = await getAllPosts();
const pinnedPosts = getPinnedPosts(posts);
const regularPosts = getRegularPosts(posts);
const categories = collectCategories(posts);
---

<BaseLayout title="文章">
  <PageHeader title="文章" eyebrow="Archive" description="这里收纳所有公开笔记。可按分类筛选，从最新文章开始慢慢翻。" />
  <section>
    <div class="mb-7 flex flex-wrap items-center gap-2" aria-label="按分类筛选文章">
      <button class="archive-filter is-active rounded-full border border-ink-200 bg-white/70 px-4 py-2 text-sm font-semibold text-ink-700 shadow-soft transition hover:border-leaf-300 hover:text-leaf-700 dark:border-white/10 dark:bg-white/5 dark:text-ink-100" type="button" data-category="all" aria-pressed="true">全部 <span class="opacity-60">{posts.length}</span></button>
      {categories.map(([category, count]) => (
        <button class="archive-filter rounded-full border border-ink-200 bg-white/55 px-4 py-2 text-sm text-ink-600 transition hover:border-leaf-300 hover:bg-leaf-50 hover:text-leaf-700 dark:border-white/10 dark:bg-white/5 dark:text-ink-200 dark:hover:bg-leaf-300/10" type="button" data-category={category} aria-pressed="false">{category} <span class="opacity-60">{count}</span></button>
      ))}
    </div>
    {pinnedPosts.length > 0 && (
      <section class="mb-10" aria-labelledby="pinned-posts-heading">
        <div class="mb-4 flex items-center gap-3">
          <span class="grid h-9 w-9 place-items-center rounded-xl bg-amber-100 text-amber-700 dark:bg-amber-300/10 dark:text-amber-100">📌</span>
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-amber-700 dark:text-amber-200">Pinned</p>
            <h2 id="pinned-posts-heading" class="text-xl font-semibold text-ink-950 dark:text-white">置顶文章</h2>
          </div>
        </div>
        <div class="space-y-4">
          {pinnedPosts.map((post) => <PostCard post={post} featured />)}
        </div>
      </section>
    )}
    <section class="border-t border-ink-200/70 pt-8 dark:border-white/10" aria-labelledby="regular-posts-heading">
      <div class="mb-5 flex items-end justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-400">All posts</p>
          <h2 id="regular-posts-heading" class="mt-1 text-xl font-semibold text-ink-950 dark:text-white">全部文章</h2>
        </div>
        <p id="archive-status" class="text-sm text-ink-500 dark:text-ink-300">按发布时间倒序 · {regularPosts.length} 篇</p>
      </div>
      <div id="archive-list" class="space-y-4">
        {regularPosts.map((post) => <div data-post-category={post.data.category}><PostCard post={post} /></div>)}
      </div>
    </section>
    <div id="archive-empty" class="hidden rounded-2xl border border-dashed border-ink-200 bg-white/50 p-8 text-center text-sm text-ink-500 dark:border-white/10 dark:bg-white/5 dark:text-ink-300">这个分类暂时没有公开文章。</div>
  </section>

  <script>
    const filters = document.querySelectorAll<HTMLButtonElement>(".archive-filter");
    const items = document.querySelectorAll<HTMLElement>("[data-post-category]");
    const status = document.querySelector("#archive-status");
    const empty = document.querySelector("#archive-empty");

    filters.forEach((filter) => {
      filter.addEventListener("click", () => {
        const category = filter.dataset.category ?? "all";
        let visible = 0;
        items.forEach((item) => {
          const match = category === "all" || item.dataset.postCategory === category;
          item.classList.toggle("hidden", !match);
          if (match) visible += 1;
        });
        filters.forEach((button) => {
          const active = button === filter;
          button.classList.toggle("is-active", active);
          button.setAttribute("aria-pressed", String(active));
        });
        if (status) status.textContent = category === "all" ? `按发布时间倒序 · ${visible} 篇` : `正在浏览「${category}」的 ${visible} 篇文章`;
        empty?.classList.toggle("hidden", visible > 0);
      });
    });
  </script>
</BaseLayout>
