---
import PageHeader from "../../components/PageHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectCategories, getAllPosts, getCategoryUrl } from "../../lib/posts";

const posts = await getAllPosts();
const categories = collectCategories(posts);
---

<BaseLayout title="分类">
  <PageHeader title="分类" eyebrow="Categories" description="按知识领域整理文章，让长期积累有一个清楚的抽屉。" />
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    {categories.map(([category, count]) => (
      <a class="group rounded-lg border border-white/70 bg-white/68 p-5 shadow-soft transition duration-300 hover:-translate-y-1 hover:border-leaf-200 hover:shadow-lift dark:border-white/10 dark:bg-white/5 dark:hover:border-leaf-300/30" href={getCategoryUrl(category)}>
        <span class="text-sm text-ink-500 dark:text-ink-300">{count} 篇文章</span>
        <h2 class="mt-3 text-2xl font-semibold text-ink-950 transition group-hover:text-leaf-700 dark:text-white dark:group-hover:text-leaf-300">{category}</h2>
      </a>
    ))}
  </div>
</BaseLayout>
