---
import PageHeader from "../../components/PageHeader.astro";
import PostCard from "../../components/PostCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { collectCategories, getAllPosts } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return collectCategories(posts).map(([category]) => ({
    params: { category },
    props: { category, posts: posts.filter((post) => post.data.category === category) },
  }));
}

const { category, posts } = Astro.props;
---

<BaseLayout title={`分类：${category}`}>
  <PageHeader title={category} eyebrow="Category" description={`这个分类下共有 ${posts.length} 篇文章。`} />
  <div class="grid gap-5 md:grid-cols-2">
    {posts.map((post) => <PostCard post={post} />)}
  </div>
</BaseLayout>
