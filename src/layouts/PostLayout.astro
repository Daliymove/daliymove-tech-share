---
import BaseLayout from "./BaseLayout.astro";
import Icon from "../components/Icon.astro";
import PostCard from "../components/PostCard.astro";
import {
  formatDate,
  getAdjacentPosts,
  getAllPosts,
  getCategoryUrl,
  getCoverUrl,
  getPostUrl,
  getReadingTime,
  getRelatedPosts,
  getTagUrl,
  withBase,
  type BlogPost,
} from "../lib/posts";

interface Props {
  post: BlogPost;
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { post, headings } = Astro.props;
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const posts = await getAllPosts();
const { prev, next } = getAdjacentPosts(posts, post);
const related = getRelatedPosts(posts, post, 3);
const cover = getCoverUrl(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={cover}
  type="article"
  canonicalPath={`/blog/${post.id.replace(/\.(md|mdx)$/i, "").replace(/\/index$/, "")}/`}
>
  <article class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_17rem]" data-pagefind-body data-reading-article>
    <div class="min-w-0">
      <a class="inline-flex items-center gap-2 text-sm font-medium text-ink-500 transition hover:text-leaf-700 dark:text-ink-300 dark:hover:text-leaf-300" href={withBase("/blog/")}>
        <span aria-hidden="true">←</span>
        返回文章列表
      </a>
      <header class="mt-6 border-b border-ink-200/70 pb-9 dark:border-white/10">
        <div class="flex flex-wrap items-center gap-2">
          <a class="inline-flex items-center gap-1 rounded-full border border-leaf-200 bg-leaf-50 px-3 py-1 text-xs font-semibold text-leaf-700 dark:border-leaf-300/20 dark:bg-leaf-300/10 dark:text-leaf-100" href={getCategoryUrl(post.data.category)}>
            <Icon name="grid" class="h-3 w-3" />
            {post.data.category}
          </a>
          {post.data.series && (
            <span class="inline-flex items-center gap-1 rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700 dark:border-blue-300/20 dark:bg-blue-300/10 dark:text-blue-100">
              <Icon name="layers" class="h-3 w-3" />
              系列 · {post.data.series}
            </span>
          )}
          {post.data.pinned && (
            <span class="inline-flex items-center gap-1 rounded-full border border-amber-200 bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-700 dark:border-amber-300/20 dark:bg-amber-300/10 dark:text-amber-100">
              置顶
            </span>
          )}
        </div>
        <h1 class="mt-5 max-w-4xl text-4xl font-semibold leading-tight tracking-normal text-ink-950 dark:text-white md:text-6xl" data-pagefind-meta="title">{post.data.title}</h1>
        <p class="mt-5 max-w-3xl text-lg leading-8 text-ink-600 dark:text-ink-300">{post.data.description}</p>
        <div class="mt-7 flex flex-wrap items-center gap-3 text-sm text-ink-500 dark:text-ink-300">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <span class="text-ink-300 dark:text-ink-600">/</span>
          <span class="inline-flex items-center gap-1">
            <Icon name="book" class="h-3.5 w-3.5" />
            {getReadingTime(post.body)}
          </span>
          {post.data.updatedDate && (
            <>
              <span class="text-ink-300 dark:text-ink-600">/</span>
              <span>更新于 {formatDate(post.data.updatedDate)}</span>
            </>
          )}
        </div>
        <div class="mt-5 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <a class="rounded-full bg-ink-100/80 px-3 py-1 text-sm text-ink-600 transition hover:bg-leaf-100 hover:text-leaf-700 dark:bg-white/10 dark:text-ink-200 dark:hover:bg-leaf-300/10" href={getTagUrl(tag)}>#{tag}</a>
          ))}
        </div>
      </header>

      {toc.length > 0 && (
        <details class="mt-6 rounded-2xl border border-white/70 bg-white/70 p-4 shadow-soft backdrop-blur-xl lg:hidden dark:border-white/10 dark:bg-white/5">
          <summary class="cursor-pointer list-none text-sm font-semibold text-ink-800 dark:text-ink-100">
            本页目录
          </summary>
          <nav class="mt-3 space-y-2 border-l border-ink-200 pl-4 dark:border-white/10">
            {toc.map((heading) => (
              <a class:list={["block leading-6 text-ink-500 transition hover:text-leaf-700 dark:text-ink-300 dark:hover:text-leaf-300", heading.depth === 3 && "pl-3 text-xs"]} href={`#${heading.slug}`}>{heading.text}</a>
            ))}
          </nav>
        </details>
      )}

      <div class="prose-blog mt-9 max-w-3xl" data-enhance-content>
        <slot />
      </div>

      <section class="mt-12 grid gap-4 border-t border-ink-200/70 pt-8 md:grid-cols-2 dark:border-white/10">
        {prev ? (
          <a class="group rounded-2xl border border-white/70 bg-white/70 p-5 shadow-soft transition hover:-translate-y-0.5 hover:border-leaf-200 dark:border-white/10 dark:bg-white/5" href={getPostUrl(prev)}>
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-400">上一篇</p>
            <p class="mt-2 text-base font-semibold text-ink-950 transition group-hover:text-leaf-700 dark:text-white dark:group-hover:text-leaf-300">{prev.data.title}</p>
          </a>
        ) : <div></div>}
        {next ? (
          <a class="group rounded-2xl border border-white/70 bg-white/70 p-5 text-right shadow-soft transition hover:-translate-y-0.5 hover:border-leaf-200 dark:border-white/10 dark:bg-white/5" href={getPostUrl(next)}>
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-400">下一篇</p>
            <p class="mt-2 text-base font-semibold text-ink-950 transition group-hover:text-leaf-700 dark:text-white dark:group-hover:text-leaf-300">{next.data.title}</p>
          </a>
        ) : <div></div>}
      </section>

      {related.length > 0 && (
        <section class="mt-12">
          <div class="mb-5 flex items-center gap-2">
            <Icon name="spark" class="h-4 w-4 text-leaf-600 dark:text-leaf-300" />
            <h2 class="text-xl font-semibold text-ink-950 dark:text-white">相关推荐</h2>
          </div>
          <div class="grid gap-4 md:grid-cols-3">
            {related.map((item) => <PostCard post={item} compact />)}
          </div>
        </section>
      )}
    </div>

    {toc.length > 0 && (
      <aside class="hidden lg:block">
        <div class="sticky top-28 rounded-2xl border border-white/70 bg-white/70 p-5 text-sm shadow-soft backdrop-blur-xl dark:border-white/10 dark:bg-white/5">
          <p class="mb-4 inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.16em] text-ink-400">
            <Icon name="layers" class="h-3.5 w-3.5" />
            本页目录
          </p>
          <nav class="space-y-2.5 border-l border-ink-200 pl-4 dark:border-white/10" data-toc-nav>
            {toc.map((heading) => (
              <a class:list={["toc-link block leading-6 text-ink-500 transition hover:text-leaf-700 dark:text-ink-300 dark:hover:text-leaf-300", heading.depth === 3 && "pl-3 text-xs"]} href={`#${heading.slug}`} data-toc-slug={heading.slug}>{heading.text}</a>
            ))}
          </nav>
        </div>
      </aside>
    )}
  </article>

  <script is:inline>
    (function enhanceArticle() {
      const progress = document.querySelector("#reading-progress");
      const article = document.querySelector("[data-reading-article]");
      const content = document.querySelector("[data-enhance-content]");
      if (!article || !content) return;

      const updateProgress = () => {
        if (!progress) return;
        const rect = article.getBoundingClientRect();
        const total = Math.max(article.offsetHeight - window.innerHeight, 1);
        const scrolled = Math.min(Math.max(-rect.top, 0), total);
        const ratio = scrolled / total;
        progress.style.transform = `scaleX(${ratio})`;
      };
      updateProgress();
      window.addEventListener("scroll", updateProgress, { passive: true });
      window.addEventListener("resize", updateProgress);

      content.querySelectorAll("pre").forEach((pre) => {
        if (pre.parentElement?.classList.contains("code-block")) return;
        const wrapper = document.createElement("div");
        wrapper.className = "code-block";
        pre.parentNode?.insertBefore(wrapper, pre);
        wrapper.appendChild(pre);

        const button = document.createElement("button");
        button.type = "button";
        button.className = "copy-code-btn";
        button.textContent = "复制";
        button.addEventListener("click", async () => {
          const text = pre.innerText;
          try {
            await navigator.clipboard.writeText(text);
            button.textContent = "已复制";
            window.setTimeout(() => {
              button.textContent = "复制";
            }, 1400);
          } catch {
            button.textContent = "失败";
            window.setTimeout(() => {
              button.textContent = "复制";
            }, 1400);
          }
        });
        wrapper.appendChild(button);
      });

      content.querySelectorAll("h2[id], h3[id]").forEach((heading) => {
        const link = document.createElement("a");
        link.href = `#${heading.id}`;
        link.className = "heading-anchor";
        link.setAttribute("aria-label", "复制标题链接");
        link.textContent = "#";
        link.addEventListener("click", async (event) => {
          event.preventDefault();
          const url = `${window.location.origin}${window.location.pathname}#${heading.id}`;
          history.replaceState(null, "", `#${heading.id}`);
          try {
            await navigator.clipboard.writeText(url);
          } catch {
            // ignore clipboard errors
          }
        });
        heading.appendChild(link);
      });

      content.querySelectorAll("img").forEach((img) => {
        img.classList.add("zoomable-image");
        img.addEventListener("click", () => {
          const overlay = document.createElement("div");
          overlay.className = "image-lightbox";
          overlay.innerHTML = `<img src="${img.getAttribute("src") || ""}" alt="${img.getAttribute("alt") || ""}" />`;
          overlay.addEventListener("click", () => overlay.remove());
          document.body.appendChild(overlay);
        });
      });

      const tocLinks = Array.from(document.querySelectorAll("[data-toc-slug]"));
      if (tocLinks.length) {
        const headings = tocLinks
          .map((link) => document.getElementById(link.getAttribute("data-toc-slug") || ""))
          .filter(Boolean);
        const observer = new IntersectionObserver(
          (entries) => {
            const visible = entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
            if (!visible?.target?.id) return;
            tocLinks.forEach((link) => {
              link.classList.toggle("is-active", link.getAttribute("data-toc-slug") === visible.target.id);
            });
          },
          { rootMargin: "-20% 0px -65% 0px", threshold: [0.1, 0.5, 1] },
        );
        headings.forEach((heading) => observer.observe(heading));
      }
    })();
  </script>
</BaseLayout>