---
import "../styles/global.css";
import Icon from "../components/Icon.astro";
import { site } from "../lib/site";
import { absoluteUrl, withBase } from "../lib/posts";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  canonicalPath?: string;
  noindex?: boolean;
}

const {
  title,
  description = site.description,
  image = withBase("/images/og/default.svg"),
  type = "website",
  canonicalPath,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} | ${site.title}` : site.title;
const currentPath = Astro.url.pathname;
const homeHref = withBase("/");
const searchHref = withBase("/search/");
const faviconHref = withBase("/favicon.svg");
const rssHref = withBase("/rss.xml");
const routePath = Astro.url.pathname.replace(import.meta.env.BASE_URL, "/") || "/";
const canonical = absoluteUrl(canonicalPath ?? routePath);
const ogPath = image.replace(import.meta.env.BASE_URL, "/") || "/images/og/default.svg";
const ogImage = image.startsWith("http") ? image : absoluteUrl(ogPath);
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&family=Noto+Serif+SC:wght@500;700&family=Noto+Sans+SC:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <meta name="description" content={description} />
    <meta name="author" content={site.author} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#161B16" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#F7F3EA" media="(prefers-color-scheme: light)" />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="alternate" type="application/rss+xml" title={`${site.title} RSS`} href={rssHref} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.title} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <title>{pageTitle}</title>
    <script is:inline>
      const savedTheme = localStorage.getItem("theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      document.documentElement.classList.toggle("dark", savedTheme ? savedTheme === "dark" : prefersDark);
    </script>
  </head>
  <body>
    <div class="page-glow" aria-hidden="true"></div>
    <div id="reading-progress" class="reading-progress" aria-hidden="true"></div>
    <a class="skip-link" href="#content">跳到正文</a>
    <header class="site-header sticky top-0 z-40 px-3 pt-3 md:px-5">
      <div class="header-shell mx-auto max-w-7xl rounded-2xl border border-white/70 bg-white/75 px-4 py-3 shadow-soft backdrop-blur-2xl transition-all dark:border-white/10 dark:bg-ink-950/70">
        <div class="flex items-center justify-between gap-4">
          <a class="flex min-w-0 items-center gap-3" href={homeHref} aria-label={`${site.title} 首页`}>
            <span class="brand-mark grid h-11 w-11 shrink-0 place-items-center rounded-xl text-sm font-black tracking-tight text-white shadow-glow">
              dM
            </span>
            <span class="hidden min-[420px]:block">
              <span class="block text-sm font-semibold tracking-wide text-ink-950 dark:text-ink-50">{site.title}</span>
              <span class="block text-xs text-ink-500 dark:text-ink-300">{site.tagline}</span>
            </span>
          </a>
          <nav class="hidden items-center gap-1 rounded-full border border-ink-200/70 bg-white/65 p-1 md:flex dark:border-white/10 dark:bg-white/5" aria-label="主导航">
            {site.nav.map((item) => {
              const href = withBase(item.href);
              const active = currentPath === href || (item.href !== "/" && currentPath.startsWith(href));
              return (
                <a class:list={["inline-flex items-center gap-1.5 rounded-full px-3.5 py-2 text-sm transition", active ? "bg-ink-950 text-white shadow-soft dark:bg-leaf-300 dark:text-ink-950" : "text-ink-600 hover:bg-ink-100 hover:text-ink-950 dark:text-ink-200 dark:hover:bg-white/10 dark:hover:text-white"]} href={href} aria-current={active ? "page" : undefined}>
                  <Icon name={item.icon} class="h-3.5 w-3.5 opacity-80" />
                  <span>{item.label}</span>
                </a>
              );
            })}
          </nav>
          <div class="flex items-center gap-2">
            <a class="hidden items-center gap-1.5 rounded-xl border border-ink-200 bg-white/70 px-3.5 py-2 text-sm font-medium text-ink-700 transition hover:border-leaf-300 hover:text-leaf-700 sm:inline-flex dark:border-white/10 dark:bg-white/5 dark:text-ink-100 dark:hover:border-leaf-500" href={searchHref} aria-label="打开搜索页，快捷键 Ctrl 或 Cmd + K">
              <Icon name="search" class="h-4 w-4" />
              搜索
              <kbd class="ml-1 rounded-md border border-ink-200 bg-ink-50 px-1.5 py-0.5 text-[10px] font-semibold text-ink-500 dark:border-white/10 dark:bg-white/5 dark:text-ink-300">⌘K</kbd>
            </a>
            <a class="grid h-10 w-10 place-items-center rounded-xl border border-ink-200 bg-white/70 text-ink-700 transition hover:border-leaf-300 hover:text-leaf-700 dark:border-white/10 dark:bg-white/5 dark:text-ink-100" href={rssHref} aria-label="RSS 订阅" title="RSS 订阅">
              <Icon name="rss" class="h-4 w-4" />
            </a>
            <button class="theme-toggle grid h-10 w-10 place-items-center rounded-xl border border-ink-200 bg-white/70 text-ink-700 transition hover:border-leaf-300 hover:text-leaf-700 dark:border-white/10 dark:bg-white/5 dark:text-ink-100" type="button" aria-label="切换深浅色模式">
              <span class="theme-icon-light" aria-hidden="true"><Icon name="sun" class="h-4 w-4" /></span>
              <span class="theme-icon-dark hidden" aria-hidden="true"><Icon name="moon" class="h-4 w-4" /></span>
            </button>
          </div>
        </div>
        <nav class="mt-3 flex gap-1 overflow-x-auto border-t border-ink-200/70 pt-3 md:hidden dark:border-white/10" aria-label="移动端导航">
          {site.nav.map((item) => {
            const href = withBase(item.href);
            const active = currentPath === href || (item.href !== "/" && currentPath.startsWith(href));
            return (
              <a class:list={["inline-flex shrink-0 items-center gap-1 rounded-full px-3 py-1.5 text-xs transition", active ? "bg-ink-950 text-white dark:bg-leaf-300 dark:text-ink-950" : "text-ink-600 hover:bg-ink-100 dark:text-ink-200 dark:hover:bg-white/10"]} href={href} aria-current={active ? "page" : undefined}>
                <Icon name={item.icon} class="h-3.5 w-3.5 opacity-80" />
                <span>{item.label}</span>
              </a>
            );
          })}
        </nav>
      </div>
    </header>
    <main id="content" class="mx-auto min-h-[calc(100vh-13rem)] max-w-7xl px-5 py-10 md:py-14"><slot /></main>
    <footer class="px-5 pb-8 text-sm text-ink-500 dark:text-ink-300">
      <div class="mx-auto flex max-w-7xl flex-col gap-3 rounded-2xl border border-white/60 bg-white/50 px-5 py-5 shadow-soft md:flex-row md:items-center md:justify-between dark:border-white/10 dark:bg-white/5">
        <div>
          <p class="font-medium text-ink-700 dark:text-ink-100">© {new Date().getFullYear()} {site.title}</p>
          <p class="mt-1">{site.tagline}</p>
        </div>
        <div class="flex flex-wrap items-center gap-3 text-ink-400 dark:text-ink-400">
          <a class="hover:text-leaf-700 dark:hover:text-leaf-300" href={rssHref}>RSS</a>
          <span>·</span>
          <a class="hover:text-leaf-700 dark:hover:text-leaf-300" href={searchHref}>搜索</a>
          <span>·</span>
          <span>Powered by Astro · Tailwind · Pagefind</span>
        </div>
      </div>
    </footer>
    <script is:inline define:vars={{ searchHref }}>
      const root = document.documentElement;
      const button = document.querySelector(".theme-toggle");
      const lightIcon = document.querySelector(".theme-icon-light");
      const darkIcon = document.querySelector(".theme-icon-dark");
      const header = document.querySelector(".site-header");
      function syncIcon() {
        const isDark = root.classList.contains("dark");
        lightIcon?.classList.toggle("hidden", isDark);
        darkIcon?.classList.toggle("hidden", !isDark);
      }
      button?.addEventListener("click", () => {
        const next = !root.classList.contains("dark");
        root.classList.toggle("dark", next);
        localStorage.setItem("theme", next ? "dark" : "light");
        syncIcon();
      });
      syncIcon();

      const onScroll = () => {
        header?.classList.toggle("is-compact", window.scrollY > 12);
      };
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      window.addEventListener("keydown", (event) => {
        const key = event.key.toLowerCase();
        const isShortcut = (event.metaKey || event.ctrlKey) && key === "k";
        if (!isShortcut) return;
        const target = event.target;
        const tag = target instanceof HTMLElement ? target.tagName : "";
        if (tag === "INPUT" || tag === "TEXTAREA" || (target instanceof HTMLElement && target.isContentEditable)) {
          if (!window.location.pathname.includes("/search")) return;
        }
        event.preventDefault();
        if (window.location.pathname.includes("/search")) {
          document.querySelector("#search-input")?.focus();
          return;
        }
        window.location.href = searchHref;
      });
    </script>
  </body>
</html>