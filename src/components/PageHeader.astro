---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  description?: string;
  eyebrow?: string;
}

const { title, description, eyebrow } = Astro.props;
---

<header class="mb-10 max-w-4xl border-b border-ink-200/70 pb-9 dark:border-white/10">
  {eyebrow && (
    <div class="mb-4 flex items-center gap-3">
      <span class="grid h-7 w-7 place-items-center rounded-lg bg-leaf-500/10 text-leaf-700 dark:text-leaf-300">
        <Icon name="spark" class="h-3.5 w-3.5" />
      </span>
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-leaf-700 dark:text-leaf-300">{eyebrow}</p>
    </div>
  )}
  <h1 class="text-4xl font-semibold leading-tight tracking-normal text-ink-950 dark:text-white md:text-5xl">{title}</h1>
  {description && <p class="mt-5 max-w-3xl text-lg leading-8 text-ink-600 dark:text-ink-300">{description}</p>}
</header>
