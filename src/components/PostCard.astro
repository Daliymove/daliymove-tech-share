---
import { formatDate, getCoverUrl, getPostUrl, getReadingTime, getTagUrl, type BlogPost } from "../lib/posts";
import Icon from "./Icon.astro";

interface Props {
  post: BlogPost;
  featured?: boolean;
  compact?: boolean;
  showDate?: boolean;
}

const { post, featured = false, compact = false, showDate = true } = Astro.props;
const cover = getCoverUrl(post);
const postUrl = getPostUrl(post);
const shortDate = new Intl.DateTimeFormat("zh-CN", { month: "2-digit", day: "2-digit" }).format(post.data.pubDate).replace("/", ".");
const year = post.data.pubDate.getFullYear();
---

<article class:list={[
  "post-card group relative overflow-hidden rounded-2xl border border-white/70 bg-white/75 shadow-soft transition duration-300 hover:-translate-y-1 hover:border-leaf-200 hover:shadow-lift dark:border-white/10 dark:bg-white/[0.055] dark:hover:border-leaf-300/40",
  compact ? "post-card-compact p-4" : "p-4 md:p-5",
  featured && "post-card-featured",
  post.data.pinned && "pinned-post-card",
]}>
  <div class:list={["pointer-events-none absolute inset-y-4 left-0 w-1 rounded-r-full bg-gradient-to-b from-leaf-600 via-leaf-500 to-bark-500 opacity-0 transition group-hover:opacity-100", post.data.pinned && "opacity-100"]}></div>

  <div class:list={["relative flex gap-4", compact ? "items-start" : "flex-col sm:flex-row sm:items-stretch md:gap-5"]}>
    {showDate && (
      <time class="post-card-date" datetime={post.data.pubDate.toISOString()} aria-label={`发布时间：${formatDate(post.data.pubDate)}`}>
        <span class="post-card-date-day">{shortDate}</span>
        <span class="post-card-date-year">{year}</span>
      </time>
    )}

    {!compact && (
      <a class="post-card-cover" href={postUrl} tabindex="-1" aria-hidden="true">
        <img class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.04]" src={cover} alt="" loading="lazy" />
      </a>
    )}

    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-2 text-xs font-medium text-ink-500 dark:text-ink-300">
        {post.data.pinned && (
          <span class="inline-flex items-center gap-1 rounded-full border border-bark-300/60 bg-bark-100 px-2.5 py-1 font-semibold text-bark-700 dark:border-bark-300/25 dark:bg-bark-500/15 dark:text-bark-300">
            <Icon name="pin" class="h-3 w-3" />
            主编领读
          </span>
        )}
        <span class="inline-flex items-center gap-1 rounded-full border border-leaf-200 bg-leaf-50 px-2.5 py-1 text-leaf-700 dark:border-leaf-300/20 dark:bg-leaf-300/10 dark:text-leaf-100">
          <Icon name="grid" class="h-3 w-3" />
          {post.data.category}
        </span>
        {post.data.series && <span class="rounded-full border border-bark-300/50 bg-bark-100 px-2.5 py-1 text-bark-700 dark:border-bark-300/25 dark:bg-bark-500/15 dark:text-bark-300">系列 · {post.data.series}</span>}
        {compact && !showDate && <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>}
        <span class="inline-flex items-center gap-1">
          <Icon name="clock" class="h-3 w-3" />
          {getReadingTime(post.body)}
        </span>
      </div>

      <h2 class:list={["mt-3 font-display font-semibold leading-snug tracking-normal text-ink-950 transition group-hover:text-leaf-700 dark:text-ink-50 dark:group-hover:text-leaf-300", featured ? "text-2xl md:text-3xl" : compact ? "text-base md:text-lg" : "text-xl md:text-2xl", post.data.pinned && "pinned-post-title"]}>
        <a class="post-card-title-link" href={postUrl}>{post.data.title}</a>
      </h2>

      {!compact && <p class="mt-3 text-sm leading-7 text-ink-600 dark:text-ink-300">{post.data.description}</p>}
      {compact && <p class="mt-2 line-clamp-2 text-sm leading-6 text-ink-500 dark:text-ink-300">{post.data.description}</p>}

      {!compact && (
        <div class="mt-5 flex flex-wrap items-center gap-2">
          {post.data.tags.slice(0, 4).map((tag) => (
            <a class="rounded-full bg-ink-100/80 px-2.5 py-1 text-xs text-ink-500 transition hover:bg-leaf-100 hover:text-leaf-700 dark:bg-white/10 dark:text-ink-300 dark:hover:bg-leaf-300/10 dark:hover:text-leaf-200" href={getTagUrl(tag)}>#{tag}</a>
          ))}
          <a class="ml-auto inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-semibold text-leaf-700 transition hover:bg-leaf-50 dark:text-leaf-300 dark:hover:bg-leaf-300/10" href={postUrl} aria-label={`阅读文章：${post.data.title}`}>
            阅读
            <Icon name="arrow" class="h-3.5 w-3.5" />
          </a>
        </div>
      )}
    </div>
  </div>
</article>
